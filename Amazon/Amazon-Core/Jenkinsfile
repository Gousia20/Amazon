
pipeline {

  agent any

  environment {
    BRANCH   = 'main'
    REPO_URL = 'https://github.com/PraveenKuberABC/Amazon-Jenkins'
    
  }

  stages {

    stage('Clone') {
      steps {
        git branch: "${BRANCH}",
        url: "${REPO_URL}"
      }
    }

    stage('Build') {
      steps {
        sh 'mvn clean install'
      }
    }
  }
}
